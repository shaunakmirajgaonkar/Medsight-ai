                    for grp, title in [(mod,"🎯 Modifiable"),(fix,"📌 Non-Modifiable")]:
                        if grp:
                            st.markdown(f"##### {title}")
                            for rp in grp:
                                pct = min(100,max(0,int(rp.get("risk_percent",0))))
                                bc  = "#DC2626" if pct>65 else "#D97706" if pct>35 else "#059669"
                                st.markdown(f"""
                                <div class="card" style="margin-bottom:.65rem">
                                    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px">
                                        <b style="color:#111827">{rp.get("condition","")}</b>
                                        <span style="font-size:1.2rem;font-weight:800;color:{bc}">{pct}%</span>
                                    </div>
                                    <div class="rbar-bg">
                                        <div class="rbar-fill" style="width:{pct}%;background:{bc}"></div>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.75rem;color:#6B7280">
                                        <span>⏱ {rp.get("timeframe","")}</span>
                                        <span>📚 {rp.get("basis","")}</span>
                                    </div>
                                </div>
                                """, unsafe_allow_html=True)
                else:
