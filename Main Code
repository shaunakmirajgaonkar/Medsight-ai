                        st.rerun()
                with co2:
                    if HAS_RL:
                        pdf = generate_pdf_report(h["result"], h.get("patient_data",{}), {"timestamp":h["ts"],"model":h.get("model",""),"elapsed":h["elapsed"]})
                        st.download_button("⬇️ PDF", data=pdf, file_name=f"MedInsight_{h['ts'].replace(':','')}.pdf", mime="application/pdf", key=f"pdf_{i}")
                with co3:
                    st.download_button("⬇️ JSON", data=json.dumps(h["result"],indent=2), file_name=f"MedInsight_{h['ts'].replace(':','')}.json", mime="application/json", key=f"js_{i}")
