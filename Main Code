        ix_tbl = Table(ix_data, colWidths=[W*.2, W*.1, W*.25, W*.25, W*.2])
        ix_tbl.setStyle(tbl_style())
        story.append(ix_tbl)
        story.append(Spacer(1,3*mm))

    # ── Follow-up ──
    fu = result.get("follow_up",{})
    if fu:
        story.append(Paragraph("FOLLOW-UP PLAN", S["h2"]))
        fu_rows = [
            [Paragraph("<b>Timeframe</b>", S["bold"]), Paragraph(fu.get("timeframe","—"), S["body"])],
            [Paragraph("<b>Monitor</b>", S["bold"]),   Paragraph("  ·  ".join(fu.get("monitoring",[])), S["body"])],
        ]
        if fu.get("red_flags"):
            fu_rows.append([Paragraph("<b>Red Flags</b>", S["bold"]), Paragraph("  ·  ".join(fu.get("red_flags",[])), S["red"])])
        fu_tbl = Table(fu_rows, colWidths=[W*.2, W*.8])
        fu_tbl.setStyle(TableStyle([
            ("BACKGROUND",(0,0),(0,-1),C_GRLT),
            ("GRID",(0,0),(-1,-1),0.5,C_BORDER),
            ("TOPPADDING",(0,0),(-1,-1),6),
            ("BOTTOMPADDING",(0,0),(-1,-1),6),
            ("LEFTPADDING",(0,0),(-1,-1),8),
        ]))
        story.append(fu_tbl)
        story.append(Spacer(1,4*mm))

    # ── Patient data reference ──
    story.append(HRFlowable(width=W, thickness=0.5, color=C_BORDER))
    story.append(Spacer(1,2*mm))
    story.append(Paragraph("PATIENT DATA USED FOR THIS ANALYSIS", sty("pd_hd", fontName="Helvetica-Bold", fontSize=8, textColor=C_GRAY2, spaceAfter=3)))
    fields = ["demographics","chief_complaint","history","vitals","symptoms","labs","medications","notes"]
    labels = ["Demographics","Chief Complaint","History","Vitals","Symptoms","Labs","Medications","Notes"]
    pd_data = [[Paragraph(f"<b>{l}</b>", S["small"]), Paragraph(patient.get(f,"—") or "—", S["small"])]
               for f, l in zip(fields, labels) if patient.get(f,"").strip()]
    if pd_data:
        pd_tbl = Table(pd_data, colWidths=[W*.2, W*.8])
        pd_tbl.setStyle(TableStyle([
            ("GRID",(0,0),(-1,-1),0.3,C_BORDER),
            ("TOPPADDING",(0,0),(-1,-1),4),
            ("BOTTOMPADDING",(0,0),(-1,-1),4),
            ("LEFTPADDING",(0,0),(-1,-1),6),
            ("ROWBACKGROUNDS",(0,0),(-1,-1),[WHITE,C_GRLT]),
        ]))
        story.append(pd_tbl)

    # ── Disclaimer footer ──
    story.append(Spacer(1,4*mm))
    story.append(HRFlowable(width=W, thickness=1, color=C_GREEN))
    story.append(Spacer(1,2*mm))
