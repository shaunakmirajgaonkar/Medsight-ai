# DOCUMENT EXTRACTION
# ══════════════════════════════════════════════════════════════════════════════
def extract_file(uploaded_file) -> tuple[str, str]:
    name = uploaded_file.name.lower()
    raw  = uploaded_file.read()
    if name.endswith(".pdf"):
        if not HAS_PDF: return "", "Install pymupdf: pip install pymupdf"
        try:
            doc  = fitz.open(stream=raw, filetype="pdf")
            text = "".join(p.get_text() for p in doc)
            return text.strip(), f"PDF ({doc.page_count}p)"
        except Exception as e: return "", str(e)
    elif name.endswith(".docx"):
        if not HAS_DOCX: return "", "Install python-docx"
        try:
            d = DocxDoc(io.BytesIO(raw))
            WNS = "{http://schemas.openxmlformats.org/wordprocessingml/2006/main}"
            parts = []
            for child in d.element.body:
                tag = child.tag.split("}")[-1] if "}" in child.tag else child.tag
                if tag == "p":
                    para_text = "".join(
                        node.text or "" for node in child.iter()
                        if node.tag.endswith("}t")
                    ).strip()
                    if para_text:
                        parts.append(para_text)
                elif tag == "tbl":
                    for row in child.findall(".//{" + WNS[1:-1] + "}tr"):
                        cells = []
                        for cell in row.findall(".//{" + WNS[1:-1] + "}tc"):
                            ct = "".join(node.text or "" for node in cell.iter() if node.tag.endswith("}t")).strip()
                            if ct:
                                cells.append(ct)
                        if len(cells) == 1:
                            parts.append(cells[0])
                        elif len(cells) == 2:
                            parts.append(f"{cells[0]}: {cells[1]}")
                        elif len(cells) >= 3:
                            parts.append(" | ".join(cells))
            text = "\n".join(parts)
            return text.strip(), f"DOCX (paragraphs + {len(d.tables)} tables)"
        except Exception as e: return "", str(e)
    elif name.endswith((".txt",".md",".csv",".log")):
        return raw.decode("utf-8","replace").strip(), "Plain text"
    elif name.endswith((".png",".jpg",".jpeg",".bmp",".tiff",".webp")):
        if not HAS_OCR: return "", "Install pytesseract + Pillow"
        try:
            text = pytesseract.image_to_string(Image.open(io.BytesIO(raw)))
            return text.strip(), "Image OCR"
        except Exception as e: return "", str(e)
    return "", f"Unsupported: {Path(name).suffix}"

def smart_parse(text: str) -> dict:
    """
    Section-aware medical document parser v3.
    Maps document sections to patient form fields cleanly.
    """
    fields = {k: "" for k in
              ["demographics", "chief_complaint", "history",
               "vitals", "symptoms", "labs", "medications", "notes"]}
    if not text:
        return fields

    JUNK_PAT = re.compile(
        r"^(===.*===|CONFIDENTIAL|PATIENT MEDICAL RECORD$"
        r"|City General Hospital|Department of Internal Medicine"
        r"|MRN:.*Prepared:|FOR CLINICAL USE ONLY|Page \d+)",
        re.IGNORECASE
    )
    TABLE_HDR_PAT = re.compile(
        r"^(Parameter|Result|Reference|Status|Drug|Dose|Frequency|Indication"
        r"|Value|Test|Finding|Measurement)\s*\|",
        re.IGNORECASE
    )

    SECTION_MAP = [
        (r"PATIENT\s+DEMOGRAPHICS?",                        "demographics"),
        (r"DEMOGRAPHICS?\b",                                "demographics"),
        (r"PERSONAL\s+INFO",                                "demographics"),
        (r"CHIEF\s+COMPLAINT",                              "chief_complaint"),
        (r"PRESENTING\s+(COMPLAINT|HISTORY|ILLNESS)",       "chief_complaint"),
        (r"HISTORY\s+OF\s+PRESENTING",                     "chief_complaint"),
        (r"REASON\s+FOR\s+(VISIT|REFERRAL)",               "chief_complaint"),
        (r"PAST\s+MEDICAL.*SURGICAL.*HISTORY",              "history"),
        (r"PAST\s+MEDICAL.*HISTORY",                        "history"),
        (r"MEDICAL\s+(HISTORY|BACKGROUND)",                 "history"),
        (r"SURGICAL\s+HISTORY",                             "history"),
        (r"FAMILY\s+HISTORY",                               "history"),
        (r"SOCIAL\s+HISTORY",                               "history"),
        (r"VITAL\s+SIGNS?\s*(ON\s+ADMISSION)?",           "vitals"),
        (r"VITALS?\b",                                      "vitals"),
        (r"PHYSICAL\s+EXAM(INATION)?",                      "vitals"),
        (r"OBSERVATIONS?\b",                                "vitals"),
        (r"SYMPTOMS?\b",                                    "symptoms"),
        (r"REVIEW\s+OF\s+SYSTEMS?",                        "symptoms"),
        (r"PRESENTING\s+SYMPTOMS?",                         "symptoms"),
        (r"COMPLAINTS?\b",                                  "symptoms"),
        (r"LABORATORY\s+(INVESTIGATIONS?|RESULTS?|FINDINGS?|TESTS?)", "labs"),
        (r"LAB(ORATORY)?\s+(RESULTS?|VALUES?|DATA|PANEL)", "labs"),
        (r"INVESTIGATIONS?\b",                              "labs"),
        (r"DIAGNOSTIC\s+(RESULTS?|FINDINGS?|WORKUP)",       "labs"),
        (r"ELECTROCARDIOGRAM|ECG\b|IMAGING\b",             "labs"),
        (r"HAEMATOLOGY|HEMATOLOGY|BIOCHEMISTRY",             "labs"),
        (r"CARDIAC\s+BIOMARKERS?",                          "labs"),
        (r"METABOLIC\s+PANEL",                              "labs"),
        (r"CURRENT\s+MEDICATIONS?",                         "medications"),
        (r"MEDICATIONS?\s*(LIST|PRESCRIBED|ON\s+ADMISSION)?","medications"),
        (r"PRESCRIPTION(S)?\b",                             "medications"),
        (r"DRUGS?\s*(LIST|PRESCRIBED|CURRENT)",             "medications"),
        (r"PHYSICIAN\s+(CLINICAL\s+)?IMPRESSION",          "notes"),
        (r"CLINICAL\s+(IMPRESSION|NOTES?|SUMMARY)",         "notes"),
        (r"ASSESSMENT\s+AND\s+PLAN",                       "notes"),
        (r"PENDING\s*/\s*PLANNED",                         "notes"),
    ]

    DEMO_KV_PAT = re.compile(
        r"^(Full\s+Name|Name|Patient(\s+Name)?|Date\s+of\s+Birth|DOB"
        r"|Age|Sex|Gender|Weight\s*/\s*BMI|BMI|Occupation|Job"
        r"|MRN|Ward|Bed|Attending|Date\s+of\s+Admission|Admission\s+Date"
        r"|Smoking(\s+History)?|Alcohol|Marital|Nationality)\s*:",
        re.IGNORECASE
    )
    VITAL_DATA_PAT = re.compile(
        r"\b(Blood\s+Pressure|BP|Pulse|Heart\s+Rate|HR|Respiratory\s+Rate|RR"
        r"|SpO2|O2\s+Sat|Temperature|Temp|Weight|Height|BMI)\b"
        r".{0,30}[\d\.]+\s*(mmHg|bpm|breaths/min|%|[°]?[CF]|kg|cm)",
        re.IGNORECASE
    )
    LAB_DATA_PAT = re.compile(
        r"\b(HbA1c|Haemoglobin|Hemoglobin|Hb\b|WBC|Platelets?"
        r"|Creatinine|eGFR|BUN|Urea\b|Sodium|Potassium|Chloride"
        r"|LDL|HDL|Triglycerides?|Total\s+Cholesterol"
        r"|BNP|Troponin|CK.?MB|D.?Dimer|INR|PT\b|APTT"
        r"|TSH|FT4|FT3|Anti.?TPO|Prolactin|FSH|LH|Cortisol"
        r"|Ferritin|Iron\b|Folate|Vitamin\s+B12|B12\b"
        r"|ALT|AST|ALP|GGT|Bilirubin|Albumin"
        r"|Fasting\s+Blood\s+Sugar|FBS|Blood\s+Glucose|HBA1C"
        r"|MMSE|MoCA|PSA|AFP|CEA)\b"
        r".{0,20}[\d\.]+",
        re.IGNORECASE
    )
    MED_DATA_PAT = re.compile(
        r"\b(Metformin|Amlodipine|Atorvastatin|Lisinopril|Losartan"
        r"|Aspirin|Clopidogrel|Warfarin|Levothyroxine|Insulin"
        r"|Escitalopram|Sertraline|Omeprazole|Pantoprazole"
        r"|Metoprolol|Bisoprolol|Furosemide|Spironolactone|Tamsulosin"
        r"|Paracetamol|Ibuprofen|Diclofenac|Prednisone|Prednisolone"
        r"|Amoxicillin|Azithromycin|Ramipril|Enalapril|Valsartan"
        r"|\w+statin|\w+pril|\w+sartan|\w+olol|\w+pine|\w+mide"
        r"|\w+zide|\w+mycin|\w+cillin|\w+oxacin|\w+azole|\w+prazole"
        r"|\w+tidine|\w+gliptin|\w+formin|\w+insulin)\b"
        r".{0,30}\d+\s*(mg|mcg|g\b|ml|IU|units?)",
        re.IGNORECASE
    )

    lines = text.split("\n")
    current_section = None
    section_content = {k: [] for k in fields}

    def detect_header(line):
        s = line.strip().rstrip(":.\u2014\u2013-")
        if not s or len(s) > 100:
            return None
        if re.search(r"\d+\s*(mg|mmHg|bpm|%|ng|pg|mL|IU|kg|g/dL|U/L|mEq)", s):
            return None
        if s.count("|") >= 2 and re.search(r"\d", s):
            return None
        clean = re.sub(r"^[\d]+\.[\d]*\s+", "", s)
        clean = re.sub(r"^\d+\.\s+", "", clean)
        for pat, key in SECTION_MAP:
            if re.search(pat, clean, re.IGNORECASE):
                return key
        return None

    for raw_line in lines:
        line = raw_line.strip()
        if not line:
            continue
        if JUNK_PAT.search(line):
            continue
        if TABLE_HDR_PAT.search(line) and not re.search(r"\d", line):
            continue

        detected = detect_header(line)
        if detected:
            if detected == "notes" and current_section in (
                    "vitals","labs","medications","symptoms",
                    "history","chief_complaint","demographics"):
                section_content[current_section].append(line)
            else:
                current_section = detected
            continue

        if current_section:
            section_content[current_section].append(line)
        else:
            if DEMO_KV_PAT.match(line):
                section_content["demographics"].append(line)
            elif VITAL_DATA_PAT.search(line):
                section_content["vitals"].append(line)
            elif LAB_DATA_PAT.search(line):
                section_content["labs"].append(line)
            elif MED_DATA_PAT.search(line):
                section_content["medications"].append(line)

    if not section_content["vitals"]:
        for ln in lines:
            if VITAL_DATA_PAT.search(ln) and not TABLE_HDR_PAT.search(ln):
                section_content["vitals"].append(ln.strip())
    if not section_content["labs"]:
        for ln in lines:
            if LAB_DATA_PAT.search(ln):
                section_content["labs"].append(ln.strip())
    if not section_content["medications"]:
        for ln in lines:
            if MED_DATA_PAT.search(ln):
                section_content["medications"].append(ln.strip())

    def clean_vitals(lst):
        out = []
        for ln in lst:
            ln = ln.strip()
            if TABLE_HDR_PAT.search(ln) and not re.search(r"\d", ln):
                continue
            if "|" in ln and not re.search(r"\d", ln):
                continue
            ln = re.sub(r"\s*[|]\s*([\u2713\u26a0]|\xe2\x9c\x93|\xe2\x9a\xa0)\s*(NORMAL|HIGH|LOW|CRITICAL)\s*$", "", ln)
            ln = re.sub(r"\s+[\u2713\u26a0\u2714]\s*(NORMAL|HIGH|LOW|CRITICAL)", "", ln)
            ln = re.sub(r"\s*\|\s*(NORMAL|HIGH|LOW|CRITICAL)\s*$", "", ln)
            if ln.strip():
                out.append(ln.strip())
        return out

    def clean_labs(lst):
        out, seen = [], set()
        for ln in lst:
            ln = ln.strip()
            if TABLE_HDR_PAT.search(ln) and not re.search(r"\d", ln):
                continue
            if ln and ln not in seen:
                seen.add(ln); out.append(ln)
        return out

    def clean_meds(lst):
        out = []
        for ln in lst:
            ln = ln.strip()
            if re.match(r"^(Drug|Medication)\s*\|", ln, re.IGNORECASE):
                continue
            # Drop section-header lines that leaked in (e.g. "8. PHYSICIAN CLINICAL IMPRESSION")
            if re.match(r"^\d+[\. ]+[A-Z][A-Z\s]+$", ln):
                continue
            if re.search(r"PHYSICIAN|CLINICAL IMPRESSION|ASSESSMENT\s+AND\s+PLAN", ln, re.IGNORECASE):
                continue
            # Every real medication line has a dose number
            if not re.search(r"\d", ln):
                continue
            if ln:
                out.append(ln)
        return out

    def clean_demographics(lst):
        # Split fused lines like "Full Name: JohnDate of Birth: 1990"
        LABELS = (r"(Full\s+Name|Name|Date\s+of\s+Birth|DOB|Age|Sex|Gender"
                  r"|Weight\s*/\s*BMI|BMI|Occupation|MRN|Ward|Bed"
                  r"|Attending|Date\s+of\s+Admission|Smoking(\s+History)?"
                  r"|Alcohol|Marital|Nationality|Allergies|Immunisations?|Surgical\s+History)")
        split_pat = re.compile(r"(?<=[a-z0-9\)])(?=" + LABELS + r"\s*:)", re.IGNORECASE)
        out = []
        for ln in lst:
            parts = split_pat.split(ln.strip())
            for p in parts:
                p = p.strip()
                if p:
                    out.append(p)
        return out

    def join_unique(lst, sep, limit):
        seen, out = set(), []
        for ln in lst[:limit]:
            ln = ln.strip()
            if ln and ln not in seen:
                seen.add(ln); out.append(ln)
        return sep.join(out)

    fields["demographics"]    = join_unique(clean_demographics(section_content["demographics"]), "\n", 15)
    fields["chief_complaint"] = join_unique(section_content["chief_complaint"], "\n", 10)
    fields["history"]         = join_unique(section_content["history"],         "\n", 15)
    fields["vitals"]          = join_unique(clean_vitals(section_content["vitals"]), " | ", 10)
    fields["symptoms"]        = join_unique(section_content["symptoms"],        "\n", 12)
    fields["labs"]            = join_unique(clean_labs(section_content["labs"]), " | ", 20)
    fields["medications"]     = join_unique(clean_meds(section_content["medications"]), "\n", 15)
    fields["notes"]           = join_unique(section_content["notes"],           "\n", 12)

    if not fields["symptoms"] and fields["chief_complaint"]:
        symp_lines = [
            ln for ln in section_content["chief_complaint"]
            if re.search(r"(tightness|pain|ache|dyspnoea|dyspnea|fatigue"
                         r"|diaphoresis|nausea|vomit|dizziness|syncope"
                         r"|palpitation|swelling|fever|cough|headache"
                         r"|weakness|numbness|tingling|loss\s+of)", ln, re.IGNORECASE)
        ]
        fields["symptoms"] = join_unique(symp_lines, "\n", 10)

    if not any(v.strip() for v in fields.values()):
        fields["notes"] = text[:3000]

    return fields


