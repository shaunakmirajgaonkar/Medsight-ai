            st.warning("Install reportlab for PDF export: `pip install reportlab`")

        st.markdown("---")

        # ── Detail tabs ──
        rt1,rt2,rt3,rt4,rt5 = st.tabs(["🧬 Differentials","🔬 Labs","📊 Risk","💊 Drugs","📋 Recs"])

        with rt1:
            if active.get("🧬 Differentials"):
                diffs = R.get("differentials",[])
                if diffs:
                    for i, d in enumerate(diffs):
                        conf = int(d.get("confidence_percent",0))
                        cc   = "#DC2626" if conf>70 else "#D97706" if conf>40 else "#059669"
                        kf   = d.get("key_features",[])
                        ag   = d.get("against","")
                        kfh  = "".join(f'<span class="badge b-gray">{k}</span>' for k in kf[:4])
                        st.markdown(f"""
                        <div class="card" style="margin-bottom:.7rem">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                                <b style="font-size:.95rem;color:#111827">{i+1}. {d.get("condition","")}</b>
                                <div>{prob_badge(d.get("probability",""))} <span class="badge b-gray">{d.get("icd10","")}</span></div>
                            </div>
                            <div style="font-size:.72rem;color:#6B7280;margin-bottom:4px">
                                CONFIDENCE &nbsp;<b style="color:{cc}">{conf}%</b>
