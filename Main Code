                                <b style="font-family:'JetBrains Mono',monospace;font-size:.88rem;color:#111827">{drugs}</b>
                                {sev_badge(sv)}
                            </div>
                            {f'<p style="font-size:.78rem;color:#6B7280;margin:.3rem 0"><b style="color:#374151">Mechanism:</b> {ix.get("mechanism","")}</p>' if ix.get("mechanism") else ""}
                            <p style="font-size:.84rem;color:#374151;margin:.3rem 0"><b>Effect:</b> {ix.get("effect","")}</p>
                            <p style="font-size:.82rem;color:#374151;margin:.3rem 0"><b>Action:</b> {ix.get("action","")}</p>
                            {f'<p style="font-size:.77rem;color:#6B7280;margin:.3rem 0"><b>Monitor:</b> {ix.get("monitoring","")}</p>' if ix.get("monitoring") else ""}
                        </div>
                        """, unsafe_allow_html=True)
                else:
                    st.markdown('<div class="card card-green"><span style="color:#059669;font-weight:700">✓</span> No significant drug interactions identified.</div>', unsafe_allow_html=True)
            else:
                st.info("Module disabled.")

        with rt5:
            if active.get("📋 Recs"):
                recs = R.get("recommendations",[])
                if recs:
                    by_cat = {}
                    for rec in recs:
                        by_cat.setdefault(rec.get("category","Other"),[]).append(rec)
                    icons = {"Investigation":"🔬","Medication":"💊","Referral":"🏥","Monitoring":"📈","Lifestyle":"🌿","Other":"📋"}
                    for cat in ["Investigation","Medication","Referral","Monitoring","Lifestyle","Other"]:
                        items = by_cat.get(cat,[])
                        if not items: continue
                        st.markdown(f"##### {icons.get(cat,'📋')} {cat}")
                        for rec in items:
                            eg = rec.get("evidence_grade","")
                            st.markdown(f"""
                            <div class="card" style="margin-bottom:.5rem">
                                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px">
                                    <span style="font-size:.9rem;font-weight:600;color:#111827">{rec.get("action","")}</span>
                                    <div>{prio_badge(rec.get("priority",""))} {grade_badge(eg) if eg else ""}</div>
                                </div>
                                <div style="font-size:.77rem;color:#6B7280">📚 {rec.get("evidence","")}</div>
                            </div>
                            """, unsafe_allow_html=True)
                else:
                    st.info("No recommendations returned.")
            else:
                st.info("Module disabled.")

        # ── Export row ──
        st.markdown("---")
        e1, e2 = st.columns(2)
