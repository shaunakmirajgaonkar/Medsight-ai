        "This report is generated by an AI model running locally on-device (Ollama). "
        "All outputs must be reviewed and validated by a licensed clinician before any clinical action. "
        "This report does not constitute a diagnosis, prescription, or medical advice.",
        sty("disc", fontSize=7, textColor=C_GRAY2, alignment=TA_CENTER, leading=11)
    ))

    doc.build(story)
    return buf.getvalue()


