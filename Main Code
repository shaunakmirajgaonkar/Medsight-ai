    # ── Recommendations ──
    recs = result.get("recommendations",[])
    if recs:
        story.append(Paragraph("CLINICAL RECOMMENDATIONS", S["h2"]))
        rec_data = [["Priority","Category","Action","Evidence","Grade"]]
