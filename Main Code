                            {f'<div style="margin-bottom:6px">{kfh}</div>' if kf else ""}
                            {f'<div style="font-size:.78rem;color:#6B7280"><b style="color:#D97706">Against:</b> {ag}</div>' if ag else ""}
                        </div>
                        """, unsafe_allow_html=True)
                else:
                    st.info("No differentials returned — try a larger model.")
            else:
                st.info("Module disabled.")

        with rt2:
            if active.get("🔬 Labs"):
                labs_list = R.get("lab_analysis",[])
                if labs_list:
                    act = [l for l in labs_list if l.get("action_needed")]
                    nrm = [l for l in labs_list if not l.get("action_needed")]
                    for grp, title in [(act,"⚡ Requires Action"),(nrm,"✓ Within Reference")]:
                        if grp:
                            st.markdown(f"##### {title}")
                            for lab in grp:
                                s   = lab.get("status","NORMAL")
                                cls = {"CRITICAL":"card-red","HIGH":"card-orange","LOW":"card-blue","NORMAL":"card-green"}.get(s,"")
                                st.markdown(f"""
                                <div class="card {cls}" style="margin-bottom:.5rem">
                                    <div style="display:flex;justify-content:space-between;align-items:baseline">
                                        <b style="color:#111827">{lab.get("parameter","")}</b>
