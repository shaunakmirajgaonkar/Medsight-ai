            <div class="card card-green" style="height:100%">
                <div class="sec-label">Follow-up</div>
                <div style="font-size:.88rem;font-weight:700;color:#059669;margin-bottom:8px;">{fu.get("timeframe","—")}</div>
                {mh}
                {('<div style="margin-top:6px;font-size:.7rem;color:#6B7280;margin-bottom:3px;">RED FLAGS</div>'+rh) if reds else ''}
            </div>
            """, unsafe_allow_html=True)

        # ── PDF Download (top) ──
        if HAS_RL:
            pdf_bytes = generate_pdf_report(R, pd_, {
                "timestamp": datetime.now().strftime("%d %b %Y, %H:%M"),
