def fix_json(raw: str) -> str:
    """Repair malformed JSON from LLMs before parsing."""

    # 1. Strip markdown fences
    if "```" in raw:
        for part in raw.split("```"):
            p = part.strip()
            if p.startswith("json"):
                p = p[4:].strip()
            if p.startswith("{"):
                raw = p
                break

    # 2. Trim to outermost { ... }
    s = raw.find("{")
    e = raw.rfind("}")
    if s != -1 and e != -1 and e > s:
        raw = raw[s:e+1]
    elif s != -1:
        raw = raw[s:]  # truncated output — close below

    # 3. Replace curly/smart quotes with straight ASCII quotes
    QUOTE_MAP = [
        ("\u201c", '"'), ("\u201d", '"'),
        ("\u2018", "'"), ("\u2019", "'"),
        ("\u2032", "'"), ("\u00b4", "'"),
    ]
    for bad, good in QUOTE_MAP:
        raw = raw.replace(bad, good)

    # 4. Remove JS-style // comments
    raw = re.sub(r'(?m)(?<![:\"])//[^\n]*', '', raw)

    # 5. Fix trailing commas before } or ]
    raw = re.sub(r',(\s*[}\]])', r'\1', raw)

    # 6. Escape bare newlines/carriage-returns/tabs inside JSON string values.
    #    We match quoted strings and replace literal control chars inside them.
    def escape_string_internals(m):
        inner = m.group(0)
        inner = inner.replace('\r\n', '\\n').replace('\r', '\\n').replace('\n', '\\n')
        inner = inner.replace('\t', '\\t')
        return inner
    raw = re.sub(r'"(?:[^"\\]|\\.)*"', escape_string_internals, raw, flags=re.DOTALL)

    # 7. Fix missing commas between consecutive string values in arrays
    #    Model sometimes emits ["item1"\n    "item2"] without a comma
    raw = re.sub(r'"(\s*)\n(\s*)"', '",\\n"', raw)

    # 8. If result has no opening {, wrap it (happens when smart-quote
    #    replacement strips the leading character that wasn't a real {)
    stripped = raw.strip()
    if stripped and not stripped.startswith("{"):
        # Try to find a { inside
        brace = raw.find("{")
        if brace != -1:
            raw = raw[brace:]
        else:
            raw = "{" + raw
    # Ensure it ends with }
    if not raw.rstrip().endswith("}"):
        raw = raw.rstrip().rstrip(",") + "}"

    # 9. Attempt to close truncated JSON
    if raw.count("{") > raw.count("}") or raw.count("[") > raw.count("]"):
        raw = re.sub(r',\s*"[^"]*"\s*:\s*[^,}\]]*$', '', raw.rstrip())
        raw = re.sub(r',\s*$', '', raw.rstrip())
        opens  = max(0, raw.count("{") - raw.count("}"))
        aopens = max(0, raw.count("[") - raw.count("]"))
        raw += "]" * aopens + "}" * opens

    # 10. Final trailing-comma pass
    raw = re.sub(r',(\s*[}\]])', r'\1', raw)

    return raw


def run_ollama(model, patient, timeout=180):
    msg = f"""Analyze this patient and return ONLY a valid JSON object. No explanation. No markdown.

Demographics:    {patient.get('demographics','—')}
Chief Complaint: {patient.get('chief_complaint','—')}
History:         {patient.get('history','—')}
Vitals:          {patient.get('vitals','—')}
Symptoms:        {patient.get('symptoms','—')}
Labs/Imaging:    {patient.get('labs','—')}
Medications:     {patient.get('medications','—')}
Notes:           {patient.get('notes','—')}

Respond with JSON only, starting with {{ and ending with }}. No text before or after."""

    raw = ""
    try:
        r = requests.post(f"{OLLAMA_BASE}/api/generate", timeout=timeout, json={
            "model": model, "system": SYSTEM_PROMPT, "prompt": msg, "stream": False,
            "options": {"temperature": 0.05, "top_p": 0.9, "num_predict": 4096,
                        "repeat_penalty": 1.05},
        })
        r.raise_for_status()
        resp = r.json()
        raw  = resp.get("response", "").strip()
        tps  = round(resp.get("eval_count", 0) / max(resp.get("eval_duration", 1) / 1e9, 0.1), 1)

        # ── Attempt 1: direct parse ─────────────────────────────────────────
        fixed = fix_json(raw)
        try:
            return json.loads(fixed), tps
        except json.JSONDecodeError:
            pass

        # ── Attempt 2: stripped parse (remove non-printable chars) ──────────
        cleaned = re.sub(r'[--]', '', fixed)
        try:
            return json.loads(cleaned), tps
        except json.JSONDecodeError:
            pass

        # ── Attempt 3: retry with even simpler prompt + smaller output ───────
        st.warning("⚠️ First attempt had malformed JSON — retrying with simplified prompt…")
        simple_msg = f"""Patient: {patient.get('demographics','')}. 
Complaint: {patient.get('chief_complaint','')}. 
Labs: {patient.get('labs','')}. 
Meds: {patient.get('medications','')}.
Return ONLY JSON matching the schema. Start with {{ end with }}."""

        r2 = requests.post(f"{OLLAMA_BASE}/api/generate", timeout=timeout, json={
            "model": model, "system": SYSTEM_PROMPT, "prompt": simple_msg, "stream": False,
            "options": {"temperature": 0.0, "num_predict": 3000},
        })
        r2.raise_for_status()
        raw2  = r2.json().get("response", "").strip()
        fixed2 = fix_json(raw2)
        try:
            return json.loads(fixed2), tps
        except json.JSONDecodeError as e2:
            st.error(f"JSON parse error after retry: {e2}")
            with st.expander("🔍 Raw model output (for debugging)"):
                st.code(raw[:3000], language="text")

    except requests.exceptions.ConnectionError:
        st.error("❌  Ollama not running. Run: `ollama serve`")
    except requests.exceptions.Timeout:
        st.error(f"⏱  Timed out ({timeout}s). Try a smaller model or raise the timeout slider.")
    except Exception as e:
        st.error(f"Unexpected error: {e}")
        if raw:
            with st.expander("🔍 Raw model output"):
                st.code(raw[:2000], language="text")
    return None, 0.0

