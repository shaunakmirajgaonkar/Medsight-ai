# PDF REPORT GENERATOR
# ══════════════════════════════════════════════════════════════════════════════
def generate_pdf_report(result: dict, patient: dict, meta: dict) -> bytes:
    buf = io.BytesIO()
    doc = SimpleDocTemplate(
        buf, pagesize=A4,
        topMargin=18*mm, bottomMargin=18*mm,
        leftMargin=20*mm, rightMargin=20*mm,
    )

    # ── colours ──
    C_GREEN  = colors.HexColor("#059669")
    C_GREEN2 = colors.HexColor("#065F46")
    C_NAVY   = colors.HexColor("#1E3A5F")
    C_RED    = colors.HexColor("#DC2626")
    C_ORANGE = colors.HexColor("#D97706")
    C_BLUE   = colors.HexColor("#2563EB")
    C_GRAY   = colors.HexColor("#374151")
    C_GRAY2  = colors.HexColor("#6B7280")
    C_LGR    = colors.HexColor("#F9FAFB")
    C_BORDER = colors.HexColor("#D1D9E6")
    C_GRLT   = colors.HexColor("#D1FAE5")
    C_RDLT   = colors.HexColor("#FEE2E2")
    C_ORLT   = colors.HexColor("#FEF3C7")
    C_BLLT   = colors.HexColor("#DBEAFE")
    WHITE    = colors.white

    styles = getSampleStyleSheet()
    W = A4[0] - 40*mm  # content width

    def sty(name, **kw):
        return ParagraphStyle(name, **{"fontName":"Helvetica","fontSize":9,"textColor":C_GRAY,"leading":13,**kw})

    S = {
        "title":    sty("title",    fontName="Helvetica-Bold", fontSize=18, textColor=C_NAVY, leading=22, spaceAfter=2),
        "subtitle": sty("sub",      fontSize=8.5, textColor=C_GRAY2, spaceAfter=2),
        "h2":       sty("h2",       fontName="Helvetica-Bold", fontSize=10, textColor=C_GREEN2, spaceBefore=10, spaceAfter=4, leading=14),
        "h3":       sty("h3",       fontName="Helvetica-Bold", fontSize=9,  textColor=C_NAVY,   spaceBefore=6,  spaceAfter=3, leading=13),
        "body":     sty("body",     fontSize=9,  textColor=C_GRAY,  leading=14, spaceAfter=3),
        "bold":     sty("bold",     fontName="Helvetica-Bold", fontSize=9, textColor=C_GRAY, leading=13),
        "small":    sty("small",    fontSize=7.5, textColor=C_GRAY2, leading=11),
        "center":   sty("center",   fontSize=9,  alignment=TA_CENTER, textColor=C_GRAY),
        "red":      sty("red",      fontName="Helvetica-Bold", fontSize=9,  textColor=C_RED),
        "green":    sty("green",    fontName="Helvetica-Bold", fontSize=9,  textColor=C_GREEN),
        "orange":   sty("orange",   fontName="Helvetica-Bold", fontSize=9,  textColor=C_ORANGE),
        "blue":     sty("blue",     fontName="Helvetica-Bold", fontSize=9,  textColor=C_BLUE),
        "imp":      sty("imp",      fontName="Helvetica-BoldOblique", fontSize=9, textColor=C_NAVY, leading=14),
    }

    def tbl_style(header_bg=C_GREEN, row_alt=C_LGR):
        return TableStyle([
            ("BACKGROUND",  (0,0), (-1,0), header_bg),
            ("TEXTCOLOR",   (0,0), (-1,0), WHITE),
            ("FONTNAME",    (0,0), (-1,0), "Helvetica-Bold"),
            ("FONTSIZE",    (0,0), (-1,0), 8.5),
            ("ROWBACKGROUNDS",(0,1),(-1,-1),[WHITE, row_alt]),
            ("FONTSIZE",    (0,1), (-1,-1), 8.5),
            ("TEXTCOLOR",   (0,1), (-1,-1), C_GRAY),
            ("GRID",        (0,0), (-1,-1), 0.5, C_BORDER),
            ("ROWPADDING",  (0,0), (-1,-1), 5),
            ("VALIGN",      (0,0), (-1,-1), "TOP"),
            ("TOPPADDING",  (0,0), (-1,-1), 5),
            ("BOTTOMPADDING",(0,0),(-1,-1), 5),
            ("LEFTPADDING", (0,0), (-1,-1), 7),
            ("RIGHTPADDING",(0,0), (-1,-1), 7),
        ])

    story = []

    # ── Header band ──
    rl = result.get("risk_level","UNKNOWN")
    rs = int(result.get("risk_score",0))
    rl_color = {"CRITICAL":C_RED,"HIGH":C_ORANGE,"MODERATE":C_BLUE,"LOW":C_GREEN}.get(rl, C_GRAY)

    hdr_data = [[
        Paragraph("<b>⚕ MedInsight AI</b><br/><font size='7' color='#6B7280'>Clinical Decision Support Report</font>", sty("hh", fontName="Helvetica-Bold", fontSize=14, textColor=C_NAVY, leading=18)),
        Paragraph(f"<b>RISK: {rl}</b><br/><font size='8' color='#6B7280'>Score {rs}/100</font>", sty("rl", fontName="Helvetica-Bold", fontSize=13, textColor=rl_color, alignment=TA_RIGHT, leading=18)),
    ]]
    hdr_tbl = Table(hdr_data, colWidths=[W*0.65, W*0.35])
    hdr_tbl.setStyle(TableStyle([
        ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
        ("LINEBELOW",(0,0),(-1,0),1.5,C_GREEN),
        ("TOPPADDING",(0,0),(-1,-1),6),
        ("BOTTOMPADDING",(0,0),(-1,-1),8),
    ]))
    story.append(hdr_tbl)
    story.append(Spacer(1, 4*mm))

    # ── Meta row ──
    story.append(Paragraph(
        f"Generated: {meta.get('timestamp','')}  ·  Model: {meta.get('model','')}  ·  Inference: {meta.get('elapsed','')}s  ·  100% Local · Air-gapped",
        sty("meta", fontSize=7.5, textColor=C_GRAY2)
    ))
    story.append(Spacer(1, 3*mm))

    # ── Summary card ──
    story.append(Paragraph("CLINICAL SUMMARY", S["h2"]))
    ci = result.get("clinical_impression","")
    summ_data = [
        [Paragraph(result.get("summary","—"), S["body"])],
    ]
    if ci:
        summ_data.append([Paragraph(f"<b>Impression:</b> {ci}", S["imp"])])
    summ_tbl = Table(summ_data, colWidths=[W])
    summ_tbl.setStyle(TableStyle([
        ("BACKGROUND",(0,0),(-1,-1),C_GRLT),
        ("LEFTPADDING",(0,0),(-1,-1),10),
        ("RIGHTPADDING",(0,0),(-1,-1),10),
        ("TOPPADDING",(0,0),(-1,-1),7),
        ("BOTTOMPADDING",(0,0),(-1,-1),7),
        ("LINEAFTER",(0,0),(0,-1),3,C_GREEN),
        ("GRID",(0,0),(-1,-1),0.3,C_BORDER),
        ("ROUNDEDCORNERS",[4]),
    ]))
    story.append(summ_tbl)
    story.append(Spacer(1, 3*mm))

    # ── Urgent flags ──
    flags = result.get("urgent_flags",[])
    if flags:
        story.append(Paragraph("URGENT FLAGS", S["h2"]))
        fl_data = [[Paragraph(f"⚠  {f}", sty("fl", fontName="Helvetica-Bold", fontSize=9, textColor=C_RED, leading=14))] for f in flags]
        fl_tbl = Table(fl_data, colWidths=[W])
        fl_tbl.setStyle(TableStyle([
            ("BACKGROUND",(0,0),(-1,-1),C_RDLT),
            ("LEFTPADDING",(0,0),(-1,-1),10),
            ("TOPPADDING",(0,0),(-1,-1),5),
            ("BOTTOMPADDING",(0,0),(-1,-1),5),
            ("LINEAFTER",(0,0),(0,-1),3,C_RED),
            ("GRID",(0,0),(-1,-1),0.3,colors.HexColor("#FCA5A5")),
        ]))
        story.append(fl_tbl)
        story.append(Spacer(1,3*mm))

    # ── Differentials ──
    diffs = result.get("differentials",[])
    if diffs:
        story.append(Paragraph("DIFFERENTIAL DIAGNOSES", S["h2"]))
        d_data = [["#","Condition","Probability","Conf %","ICD-10","Reasoning"]]
