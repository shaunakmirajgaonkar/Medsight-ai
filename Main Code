def badge(text, cls): return f'<span class="badge b-{cls}">{text}</span>'

def rl_badge(rl):
    c = {"CRITICAL":"red","HIGH":"orange","MODERATE":"blue","LOW":"green"}.get(rl,"gray")
    return badge(rl, c)

def rl_color(rl):
    return {"CRITICAL":"#DC2626","HIGH":"#D97706","MODERATE":"#2563EB","LOW":"#059669"}.get(rl,"#6B7280")

def status_badge(s):
    c = {"CRITICAL":"red","HIGH":"orange","LOW":"blue","NORMAL":"green"}.get(s,"gray")
    return badge(s, c)

def prob_badge(p):
    c = {"High":"red","Moderate":"orange","Low":"green"}.get(p,"gray")
    return badge(p, c)

def prio_badge(p):
    c = {"URGENT":"red","HIGH":"orange","MODERATE":"blue","ROUTINE":"green"}.get(p,"gray")
    return badge(p, c)

def sev_badge(s):
    c = {"Major":"red","Moderate":"orange","Minor":"blue"}.get(s,"gray")
    return badge(s, c)

def grade_badge(g):
    c = {"A":"green","B":"blue","C":"gray"}.get(g,"gray")
    return badge(f"Grade {g}", c)

