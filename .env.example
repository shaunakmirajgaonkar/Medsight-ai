# MedInsight AI — Environment Variables
# Copy this file to .env and fill in values if needed.
# The app works with zero configuration out of the box.

# ── Ollama ────────────────────────────────────────────────────────────────────
# Default: http://localhost:11434
# Change only if Ollama is running on a different host/port
OLLAMA_BASE_URL=http://localhost:11434

# ── Streamlit ─────────────────────────────────────────────────────────────────
# Bind to localhost only (recommended for single-user local use)
# STREAMLIT_SERVER_ADDRESS=127.0.0.1
# STREAMLIT_SERVER_PORT=8501

# ── Optional: Default model ───────────────────────────────────────────────────
# Shown as pre-selected in the sidebar model dropdown
# DEFAULT_MODEL=llama3.1:8b
